<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Glyph Torch — Light Theme (pure white) -->
    <style name="Base.Theme.GlyphTorch" parent="Theme.Material3.Light.NoActionBar">
        <!-- Surface & background: pure white -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorSurfaceVariant">@color/white</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">#99000000</item>

        <!-- System bars: white with dark icons -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Disable Material dynamic colors -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/black</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Custom attributes -->
        <item name="toastBackgroundColor">@color/toast_bg_white</item>
        <item name="titleTextColor">@color/title_text_off_white</item>
    </style>

    <style name="Theme.GlyphTorch" parent="Base.Theme.GlyphTorch" />

    <style name="Theme.AppCompat.Translucent" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

</resources>